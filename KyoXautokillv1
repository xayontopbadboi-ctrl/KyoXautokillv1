-- 2. LOGIC: TRACKING KILLS
local player = game.Players.LocalPlayer

local function getKills()
    -- Tries to find common kill stat names used by developers
    local stats = player:FindFirstChild("leaderstats")
    if stats then
        return stats:FindFirstChild("Kills") or stats:FindFirstChild("Kills ") or stats:FindFirstChild("Kills_")
    end
    return nil
end

local killStat = getKills()

if killStat then
    -- Update function
    local function updateText()
        KillCount.Text = tostring(killStat.Value)
    end
    
    -- Listen for changes
    killStat.Changed:Connect(updateText)
    updateText()
else
    KillCount.TextSize = 12
    KillCount.TextColor3 = Color3.fromRGB(255, 80, 80)
    KillCount.Text = "Kills not found in Leaderstats"
end
